# Database (optional - API runs without it, predictions won't be persisted)
# Mac: postgresql+psycopg2://your_mac_username:your_password@localhost:5432/fake_reviews
# Windows: postgresql+psycopg2://postgres:your_password@localhost:5432/fake_reviews
DATABASE_URL=postgresql+psycopg2://your_username:your_password@localhost:5432/fake_reviews

# Set to true to require database on startup, false to run without it
DATABASE_REQUIRED=false